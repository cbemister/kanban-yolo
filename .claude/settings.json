{
  "model": "opusplan",
  "permissions": {
    "deny": [
      "Bash(git push *)",
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "allow": [
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(* --version)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Task(Explore)",
      "Task(Plan)",
      "Task(cc-code)",
      "Task(cc-debug)"
    ]
  }
}
